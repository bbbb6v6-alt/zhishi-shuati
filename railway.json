{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "name": "党史刷题App",
      "install": {
        "commands": ["pnpm install --frozen-lockfile"]
      },
      "build": {
        "commands": ["cd server && pnpm run build"]
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicy": "ON_FAILURE",
    "restartLimit": 3,
    "script": "cd server && pnpm run start"
  },
  "port": 5000
}
