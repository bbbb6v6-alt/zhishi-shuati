{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "name": "zhishi-shuati",
      "install": {
        "commands": ["pnpm install --frozen-lockfile --registry=https://registry.npmmirror.com"]
      },
      "build": {
        "commands": ["cd server && pnpm run build"]
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartThreshold": 3,
    "startCommand": "cd server && PORT=5000 pnpm run start"
  }
}
